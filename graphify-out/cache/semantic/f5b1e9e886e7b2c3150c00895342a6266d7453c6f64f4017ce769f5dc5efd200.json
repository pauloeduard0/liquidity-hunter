{"nodes": [{"id": "claude_candle", "label": "Candle", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_liquidityzone", "label": "LiquidityZone", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_marketstructure", "label": "MarketStructure", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_poizone", "label": "POIZone", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Anchored to the leg between a validated CHoCH and the first BOS in the same direction; bounds frozen at creation so the order block reflects the institutional entry region, not later price action."}, {"id": "claude_rtosweepevent", "label": "RTOSweepEvent", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_manipulationcycle", "label": "ManipulationCycle", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_behaviordivergence", "label": "BehaviorDivergence", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_retailbias", "label": "RetailBias", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_leverageliquidationmap", "label": "LeverageLiquidationMap", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_marketnarrative", "label": "MarketNarrative", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_domainmodel", "label": "DomainModel", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Domain entities", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Immutable (frozen=True), extra=forbid, validate_assignment=True Pydantic base so all domain entities are validated value objects; new entities must follow this pattern."}, {"id": "claude_ohlcvprovider", "label": "OHLCVProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Abstract port so market data sources are swappable; carries max_fetch_limit so callers never assume a fixed per-request candle cap."}, {"id": "claude_futuresdataprovider", "label": "FuturesDataProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_binancedataprovider", "label": "BinanceDataProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses raw publicGetKlines instead of ccxt fetch_ohlcv because only the raw 12-column response includes taker buy base asset volume, needed for Candle.taker_buy_volume."}, {"id": "claude_binancefuturesohlcvprovider", "label": "BinanceFuturesOHLCVProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Preferred over spot candles because they align with the futures-derived overlays (OI/funding/long-short/liquidation map), reflect leveraged flow, and allow a 1500-candle fetch limit vs spot's 1000."}, {"id": "claude_fallbackohlcvprovider", "label": "FallbackOHLCVProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Falls back to the secondary only on DataProviderRequestError (e.g. symbol with no perpetual); connection errors propagate so transient outages are not masked as missing symbols."}, {"id": "claude_binancefuturesdataprovider", "label": "BinanceFuturesDataProvider", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Data layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_volume_delta", "label": "volume_delta", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Indicators layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_swinghighdetector", "label": "SwingHighDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Liquidity layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_swinglowdetector", "label": "SwingLowDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Liquidity layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_swingstructuredetector", "label": "SwingStructureDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Liquidity layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Major (swing) structure detector; mirrors InternalStructureDetector's architecture exactly, differing only in defaults (swing_lookback=10, persistence_candles=10). Feeds market_structure_events / HTF direction; not drawn on the chart."}, {"id": "claude_internalstructuredetector", "label": "InternalStructureDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Liquidity layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses trailing active_high/active_low references (adapted from LuxAlgo SMC) instead of frozen ones so internal structure keeps surfacing BOS/CHoCH during long moves; it is the detector the chart actually renders, so all visible-structure fixes target it."}, {"id": "claude_poidetector", "label": "POIDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Liquidity layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Creates one zone per CHoCH -> first-same-direction-BOS window from the extreme candle in that window; a pending CHoCH context is cancelled by an opposing BOS so half-formed anchors are discarded."}, {"id": "claude_manipulationcycledetector", "label": "ManipulationCycleDetector", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Connects existing observations (zones, sweeps, RTO events, BOS, volume delta) into three-phase Wyckoff/SMC cycles rather than detecting anything new; works retrospectively and prospectively with timeframe-adaptive minimum accumulation."}, {"id": "claude_behaviordivergenceanalyzer", "label": "BehaviorDivergenceAnalyzer", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_leverageliquidationestimator", "label": "LeverageLiquidationEstimator", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Infers the over-leveraged side from funding sign + long/short ratio (OI growth amplifies intensity) and projects both-side liquidation bands at Binance tier-1 leverage distances; mitigated zones and order blocks are kept as entry anchors because they are real past entry areas."}, {"id": "claude_retailbiasestimator", "label": "RetailBiasEstimator", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Plain-domain-type inputs double as a feature set so a future ML-based estimator can be a drop-in replacement for the rule-based analyzer."}, {"id": "claude_retailtrapanalyzer", "label": "RetailTrapAnalyzer", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_retailbiasestimate", "label": "RetailBiasEstimate", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Psychology layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Distinct from core RetailBias: an inferred estimate rather than a measured sentiment observation."}, {"id": "claude_liquidityscoringengine", "label": "LiquidityScoringEngine", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Scoring layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_scoredliquidityzone", "label": "ScoredLiquidityZone", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Scoring layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_load_dashboard_data", "label": "load_dashboard_data", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Composition root", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single buffered fetch (visible window is its tail) avoids a redundant second fetch that could race a freshly-printed candle; the internal detector starts at a structural anchor (most recent major extreme before the visible window) instead of a fixed offset so the bootstrap trend is seeded from the price action actually entering the window."}, {"id": "claude_dashboarddata", "label": "DashboardData", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Composition root", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_narrativeengine", "label": "NarrativeEngine", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "app/narrative.py", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Lives in app/ (not psychology/) because it depends on outputs from every layer; runs last via dataclasses.replace since it needs the fully assembled DashboardData."}, {"id": "claude__reanchor_bos_close_break", "label": "_reanchor_bos_close_break", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Composition root", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Composition-level pass: re-times each BOS to the first close beyond the formed level and drops wick-only breaks; keeps detectors' state machines untouched while making plotted BOS conservative close-confirmed macro SMC events."}, {"id": "claude__drop_pre_break_reference_bos", "label": "_drop_pre_break_reference_bos", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "Composition root", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A wick that pokes beyond a still-unbroken prior BOS level ratchets the staircase extreme, so the next continuation would reference a pre-break wick attempt; a reference may only come from price action after the prior break confirms, so such BOS are dropped at composition level (per the additive-over-state-machine lesson)."}, {"id": "claude_dashboarddataresponse", "label": "DashboardDataResponse", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "API layer", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_ttlcache", "label": "TTLCache", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "API layer", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "10s TTL on /api/dashboard (vs default 300s) because the frontend polls to stay near-live while still avoiding redundant Binance requests."}, {"id": "claude_mainchart", "label": "MainChart", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "React frontend", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Draws BOS and CHoCH lines at reference_price_level (the broken level) starting at reference_timestamp (the level's origin), because the breaking pivot's extreme can be far beyond the confirmed level; renders internal_structure_events for all timeframes."}, {"id": "claude_poiboxesprimitive", "label": "POIBoxesPrimitive", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "React frontend", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_liquidationbandsprimitive", "label": "LiquidationBandsPrimitive", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "React frontend", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Color encodes leverage tier (warmer = higher) since only relevant bands are drawn; the chart declutters to a proximity-weighted near-price subset while the full band set stays in the API for backtesting."}, {"id": "claude_manipulationcyclespanel", "label": "ManipulationCyclesPanel", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": "React frontend", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "claude_bos_staircase", "label": "BOS Staircase", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A continuation BOS must extend the leg beyond the previous BOS level; breaking a higher trailing low/lower trailing high formed during a retrace is not structural. Seeded at each CHoCH with the CHoCH level so the first BOS of a leg cannot form on the wrong side of the CHoCH."}, {"id": "claude_close_break_confirmation", "label": "Close-Break BOS Confirmation", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "State advances only when a candle closes beyond the active reference; a wick-only overshoot freezes the reference instead of trailing it, so a later close on the same level still activates the BOS. Conservative macro-SMC choice: fewer/later events accepted."}, {"id": "claude_choch_persistence_confirmation", "label": "CHoCH Persistence Confirmation", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A counter-trend break must hold for persistence_candles consecutive closes (is_sustained_break) to be a CHoCH; a poke that reverts is a LIQUIDITY_SWEEP. Replaced volume-delta confirmation entirely. The CHoCH reference is the validated pullback of the last continuation-confirmed BOS, promoted via a continuation gate so a retrace pullback cannot ratchet it."}, {"id": "claude_leg_origin_choch_ref", "label": "Leg-Origin CHoCH Reference", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every emitted BOS promotes its leg origin (the extreme the breaking leg launched from) directly to the opposite validated CHoCH reference, marked structural: the close-break plus confirming pullback is itself continuation evidence, so the reference need not wait for the continuation gate. Re-anchors refuse to slide a structural reference while within the 4% release gap; beyond it staleness regains authority (otherwise coarse timeframes lose whole reversal sequences). Stricter variants rejected by measurement."}, {"id": "claude_impulse_bos_staging", "label": "Impulse BOS Staging", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A clean impulsive leg has no pullback pivots to confirm BOS, leaving long event-free stretches; displacement-qualified state-advances are staged as additive marks, deduped against real BOS at the end. Chosen over a composition-level post-pass because trend + live staircase floor are only correct in-detector."}, {"id": "claude_wick_rejected_bos_staging", "label": "Wick-Rejected BOS Staging", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When the only pullback confirming a BOS is a wick (rejected by the wick filter) and no real pullback ever forms, the break would leave no mark; an additive staged BOS fills the gap without touching the state machine or CHoCH promotion \u2014 relaxing the wick filter itself was rejected by measurement because it cascaded and destroyed a correct reversal CHoCH."}, {"id": "claude_bos_pullback_wick_filter", "label": "BOS Pullback Wick Filter", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A single-candle wick can masquerade as the pullback pivot that confirms a BOS; requiring the pivot-side wick to be at most 40% of the candle range keeps the pending BOS alive until a real-bodied pullback confirms. Propagates into CHoCH detection since the confirming pullback also seeds the CHoCH candidate. Adjusting swing lookback was rejected as it coarsens all structure globally."}, {"id": "claude_staleness_reanchor", "label": "Staleness Re-anchor", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On coarse timeframes a locked trend pins the reversal reference at a distant leg origin (long-stuck-BOS pathology); after stale_reanchor_candles without a fresh BOS/flip the reversal reference is pulled to the most recent local swing extreme so a CHoCH can confirm locally, without flipping trend. Only ever tightens, and only to the correct side of price."}, {"id": "claude_choch_failed", "label": "Failed CHoCH (CHOCH_FAILED)", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A CHoCH is provisional until a same-direction BOS confirms it; a sustained break back through its origin before confirmation emits CHOCH_FAILED and flips the trend back. One-shot (no opposite origin armed) to break ping-pong chains; the resumed trend's BOS staircase is restored from a stash of the genuine pre-CHoCH floor."}, {"id": "claude_bos_confluence", "label": "BOS Confluence Filter", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Liquidity layer _common.py", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "LuxAlgo-style shadow-balance check on the breaking close candle (upper shadow > lower for bullish, reverse for bearish), mirroring LuxAlgo Smart Money Concepts' Confluence Filter; an emission-quality gate, exposed as a constructor flag so tests can exercise state-machine logic without it."}, {"id": "claude_additive_over_state_machine", "label": "Additive-over-State-Machine Principle", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Project status", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Missing marks are fixed additively (staged events, composition-level passes), never by relaxing confirmation rules \u2014 relaxed confirmations cascade through trend state and can turn a correct reversal CHoCH into a premature one."}, {"id": "claude_clean_architecture", "label": "Clean Architecture Layering", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": "Architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dependencies flow inward only toward core; each top-level package is a layer with documented responsibility and allowed dependencies. The project is explicitly a research platform, not a trading system: no strategies, execution, signals, or recommendations."}], "edges": [{"source": "claude_binancedataprovider", "target": "claude_ohlcvprovider", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": "Data layer", "weight": 1.0}, {"source": "claude_binancefuturesohlcvprovider", "target": "claude_ohlcvprovider", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "CLAUDE.md", "source_location": "Data layer", "weight": 1.0}, {"source": "claude_fallbackohlcvprovider", "target": "claude_ohlcvprovider", "relation": "implements", "confiden